# Flowless - Phase 3 (GitHub Webhook)
# Copy to .env and fill in your keys

OPENAI_API_KEY=sk-...

# GitHub webhook (Faz 3)
# Repo Settings → Webhooks → Add webhook → Payload URL: https://<ngrok-url>/webhook/github
# Content type: application/json, Secret: bu değeri kopyala
GITHUB_WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_PORT=3000
